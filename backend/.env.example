JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRY=7d
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=RepRush <onboarding@resend.dev>
ADMIN_EMAIL=frezwoan+reprush@gmail.com
ADMIN_PASSWORD=RepRush@Admin2025
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Web push notifications (reminders). Generate a key pair with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Push is disabled gracefully if these are not set.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@reprush.app
# IANA timezone used for the daily reminder cron jobs (default Asia/Dhaka)
REMINDER_TZ=Asia/Dhaka
